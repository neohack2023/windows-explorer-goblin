{
  "hotkey": "Ctrl+Space",
  "max_suggestions": 8,
  "history_file": "rename_history.jsonl",
  "slm": {
    "enabled": true,
    "provider": "ollama",
    "model": "qwen2.5:0.5b",
    "timeout_seconds": 2.5,
    "minimum_typed_length": 2,
    "call_when_under_suggestions": 5
  },
  "fallback_dictionary": [
    "examples",
    "experiments",
    "exports",
    "explorer-goblin",
    "explorer-goblin-experiments",
    "explorer-overlay-tests",
    "extension-tests",
    "extracts",
    "scratch",
    "dataset",
    "datasets",
    "samples",
    "sample-packs",
    "training-data",
    "training-packages",
    "texture-maps",
    "textures",
    "docs",
    "notes",
    "research",
    "src",
    "tools",
    "scripts",
    "config",
    "build",
    "dist",
    "assets",
    "tests"
  ],
  "templates": {
    "audio_sample": "{author}__{publisher}__{genre}__{instrument}__{bpm}bpm__{key}__{meter}__{sampletype}",
    "texture_map": "{material}_{maptype}_{resolution}_{variant}",
    "project_asset": "{project}_{component}_{version}_{status}",
    "repo_folder": "{project}-{purpose}",
    "experiment_folder": "{feature}-experiments"
  },
  "audio_keywords": [
    "bassline",
    "break",
    "drum",
    "glitch",
    "lead",
    "melody",
    "loop",
    "one-shot",
    "sample",
    "sfx",
    "vocal"
  ],
  "separators": [" ", "_", "-", "."]
}
